# SEC Scanner - environment template
# Copy this file to `.env` (same folder) and fill in your real values.
# The `.env` file should never be committed to git.

# Financial Modeling Prep API key
# Free tier: 250 requests/day. Sign up at https://site.financialmodelingprep.com
FMP_API_KEY=

# OPTIONAL - only needed if you switch to the local OSS EdgarTools MCP (Path B).
# Format: "Your Real Name your.real.email@example.com"
# SEC requires identification on every EDGAR request from the local flavor.
# The hosted MCP (default in this course) does NOT need this.
EDGAR_IDENTITY=

# OPTIONAL - override the default watchlist path if you keep watchlist.json elsewhere.
# WATCHLIST_PATH=./data/watchlist.json
